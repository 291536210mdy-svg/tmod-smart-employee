FROM node:20-alpine AS build

WORKDIR /app
COPY review_platform/frontend/package*.json ./
RUN npm ci
COPY review_platform/frontend ./
RUN npm run build

FROM nginx:1.27-alpine

COPY deploy/nginx/tmod-smart-employee.docker.conf /etc/nginx/conf.d/default.conf
COPY --from=build /app/dist /var/www/tmod-smart-employee

EXPOSE 80
